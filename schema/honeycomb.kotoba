// Honeycomb clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace honeycomb {

    entity Service {
        id: string @unique
        name: string
        environment: string
        language: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Error {
        id: string @unique
        serviceId: string
        message: string
        culprit: string
        count: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity Trace {
        id: string @unique
        serviceId: string
        operation: string
        durationMs: integer
        status: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Metric {
        id: string @unique
        serviceId: string
        name: string
        value: float
        unit: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Alert {
        id: string @unique
        serviceId: string
        condition: string
        severity: string
        active: boolean
        createdAt: datetime
        updatedAt: datetime
    }

    entity Incident {
        id: string @unique
        title: string
        status: string
        severity: string
        startedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
